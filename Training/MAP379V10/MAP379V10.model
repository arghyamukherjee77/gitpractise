        <focus-ctd-trigger appliance="ALWAYS" is_or="false" name="description-1" negative="false" suppressNewLine="false" triggerType="Test Description">
            <focus-ctd-single-template>
                <focus-ctd-template text="Scenario: Verify_DS_Components_on_Billing_Accounts_Tab_for_Internet_and_TV_User_with_Active_Invoice&#10;@Billing_Accounts_Tab @DS_Components&#10;Given The user is a MyBell user and is authenticated&#10;And The user has Internet and TV services on their profile&#10;And The user has one active bill on their account&#10;And The user logs in to the MyBell application&#10;And The user navigates to the Profile page&#10;And The user taps on the Billing accounts tab&#10;Then The Billing accounts tab is displayed&#10;And The Profile page header is displayed&#10;And The side navigation with &quot;Personal info and security&quot;, &quot;Communications&quot;, and &quot;Billing accounts&quot; is displayed&#10;And The bill section with &quot;Internet and TV&quot; icon, bill name and account number is displayed&#10;And 2 action list components are displayed&#10;And The mailing and billing address with body text is displayed&#10;And The bill language with body text is displayed&#10;And All DS components are working as expected&#10;And I take screenshot&#10;| Field        | Description                                      |&#10;|--------------|--------------------------------------------------|&#10;| User credentials | User credentials for a MyBell user with Internet and TV services |&#10;| Active bill  | An active bill associated with the user's account |"/>
            </focus-ctd-single-template>
            <focus-ctd-cond attribute="user_profile" operation="Equals">
                <focus-ctd-cond-val value="internet and tv"/>
            </focus-ctd-cond>
            <focus-ctd-cond attribute="user_navigated_to" operation="Equals">
                <focus-ctd-cond-val value="profile_page_billing_accounts_tab"/>
            </focus-ctd-cond>
            <focus-ctd-cond attribute="invoice" operation="Equals">
                <focus-ctd-cond-val value="active"/>
            </focus-ctd-cond>
            <focus-ctd-cond attribute="billing_accounts_tab_elements" operation="Equals">
                <focus-ctd-cond-val value="ds_component"/>
            </focus-ctd-cond>
        </focus-ctd-trigger>
