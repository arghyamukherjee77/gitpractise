        <focus-ctd-trigger appliance="ALWAYS" is_or="false" name="description-2" negative="false" suppressNewLine="false" triggerType="Test Description">
            <focus-ctd-single-template>
                <focus-ctd-template text="Scenario: Validate_DS_Component_Billing_Accounts_Tab&#10;@Billing_Accounts_Tab @DS_Component&#10;Given I log in to the MyBell application with valid credentials&#10;And I navigate to the Profile page&#10;And I tap on the Billing Accounts tab&#10;Then the Profile page header should be displayed on the Billing Accounts tab&#10;And the side navigation options should be displayed&#10;And the Bill section should display the correct icon based on the user's profile&#10;And the Bill name and account number should be displayed in the Bill section&#10;And the action list components should be displayed in the Bill section&#10;And the Mailing and billing address should be displayed with relevant body text&#10;And the Bill language should be displayed with relevant body text&#10;And all DS components on the Billing Accounts tab should be working as expected&#10;And I take screenshot"/>
            </focus-ctd-single-template>
            <focus-ctd-cond attribute="user_profile" operation="Equals">
                <focus-ctd-cond-val value="internet"/>
            </focus-ctd-cond>
            <focus-ctd-cond attribute="user_navigated_to" operation="Equals">
                <focus-ctd-cond-val value="profile_page_billing_accounts_tab"/>
            </focus-ctd-cond>
            <focus-ctd-cond attribute="invoice" operation="Equals">
                <focus-ctd-cond-val value="active"/>
            </focus-ctd-cond>
            <focus-ctd-cond attribute="billing_accounts_tab_elements" operation="Equals">
                <focus-ctd-cond-val value="ds_component"/>
            </focus-ctd-cond>
        </focus-ctd-trigger>
